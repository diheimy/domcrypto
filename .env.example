# ===========================================
# DOMCRYPTO - Variáveis de Ambiente
# ===========================================

# -------------------------------------------
# APP
# -------------------------------------------
NODE_ENV=development
PYTHON_ENV=development

# -------------------------------------------
# SERVERS
# -------------------------------------------
# Backend Python (FastAPI)
PYTHON_HOST=127.0.0.1
PYTHON_PORT=8000

# Frontend Next.js
PORT=3000
APP_URL=http://localhost:3000

# -------------------------------------------
# DATABASE (PostgreSQL)
# -------------------------------------------
DATABASE_URL=postgresql://domcrypto:password@localhost:5432/domcrypto

# PostgreSQL
POSTGRES_DB=domcrypto
POSTGRES_USER=domcrypto
POSTGRES_PASSWORD=password
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# -------------------------------------------
# EXCHANGES (API Keys)
# -------------------------------------------
# Binance
BINANCE_API_KEY=
BINANCE_API_SECRET=
BINANCE_TESTNET=true

# Bybit
BYBIT_API_KEY=
BYBIT_API_SECRET=
BYBIT_TESTNET=true

# MEXC (opcional)
MEXC_API_KEY=
MEXC_API_SECRET=

# -------------------------------------------
# TRADING CONFIG
# -------------------------------------------
# Paper Trading (true/false)
PAPER_TRADING=true

# Capital inicial (USD)
INITIAL_CAPITAL_USD=10000

# Hedge (0.0 - 1.0)
HEDGE_RATIO=1.0

# Mínimo de spread (%)
MIN_SPREAD_PCT=0.5

# Mínimo de score
MIN_SCORE=50

# Mínimo de volume 24h (USD)
MIN_VOLUME_24H_USD=100000

# -------------------------------------------
# RISK
# -------------------------------------------
# Stop loss diário (%)
DAILY_STOP_LOSS_PCT=2.0

# Exposição máxima por trade (%)
MAX_POSITION_PCT=10.0

# Drawdown máximo (%)
MAX_DRAWDOWN_PCT=5.0

# -------------------------------------------
# WEBSOCKET
# -------------------------------------------
PYTHON_WS_URL=ws://127.0.0.1:8000/ws/opportunities

# -------------------------------------------
# LOGGING
# -------------------------------------------
LOG_LEVEL=INFO
LOG_FILE=logs/domcrypto.log
